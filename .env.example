# Pluxee Monitor Configuration
# Copy this file to .env and fill in your credentials

# Your Pluxee login credentials (NIF and password)
PLUXEE_NIF=123456789
PLUXEE_PASSWORD=your_password_here

# ntfy.sh topic name — must match what you subscribed to in the ntfy Android app
NTFY_TOPIC=pluxee-tiago-a7x9k2

# How often to check for new transactions (in seconds). Default: 300 (5 minutes)
POLL_INTERVAL_SECONDS=300
